# ── OpenAI ──────────────────────────────────────────────────────
# Requerida para la app Streamlit (app/)
OPENAI_API_KEY=sk-...

# Modelo a usar (gpt-4o-mini recomendado para contextos grandes)
OPENAI_MODEL=gpt-4o-mini

# ── Scraper ─────────────────────────────────────────────────────
TARGET_BASE_URL=https://valledellili.org
REQUEST_TIMEOUT=30
HEADLESS=true

# ── Rutas de salida ─────────────────────────────────────────────
DATA_OUTPUT_PATH=./data/knowledge_base.json
KNOWLEDGE_DIR=data/knowledge

# ── Inference budget (NO-RAG) ──────────────────────────────────
RESPONSE_MAX_TOKENS=500
HISTORY_MAX_TURNS=6
HISTORY_MAX_CHARS=3500
HISTORY_ITEM_MAX_CHARS=700

# ── Context compaction ──────────────────────────────────────────
LINE_LEXICON_ENABLED=true
LINE_LEXICON_MIN_COUNT=5
LINE_LEXICON_MIN_LEN=24
LINE_LEXICON_MAX_ENTRIES=350

# ── Reintentos HTTP ─────────────────────────────────────────────
MAX_RETRIES=2

# ── YouTube enriquecido (yt-dlp) ────────────────────────────────
# Queries de búsqueda (formato JSON para múltiples valores)
YOUTUBE_SEARCH_QUERIES=["Fundación Valle del Lili","Hospital Valle del Lili"]
YOUTUBE_SEARCH_LIMIT=20
YOUTUBE_TRANSCRIPT_LANGUAGES=["es","es-419","es-CO","en"]

# ── Noticias curadas ─────────────────────────────────────────────
NEWS_CURATED_ENABLED=true
NEWS_GOOGLE_QUERIES=["Fundación Valle del Lili","FVL Cali"]
NEWS_FETCH_FULL_ARTICLE=false
NEWS_FEED_LIMIT=50

# ── Presupuesto de resumen y FAQ ────────────────────────────────
SUMMARY_MAX_TOKENS=900
FAQ_MAX_TOKENS=1200

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── RAG ─────────────────────────────────────────────
CHROMA_PERSISTENCE_DIR=./data/chroma_db
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
AGENT_MAX_ITERATIONS=6
STRUCTURED_DATA_PATH=data/structured/fvl_info.json