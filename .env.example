# ── OpenAI ──────────────────────────────────────────────────────
# Requerida para la app Streamlit (app/)
OPENAI_API_KEY=sk-...

# Modelo a usar (gpt-4o-mini recomendado para contextos grandes)
OPENAI_MODEL=gpt-4o-mini

# ── Scraper ─────────────────────────────────────────────────────
TARGET_BASE_URL=https://valledellili.org
REQUEST_TIMEOUT=30
HEADLESS=true

# ── Rutas de salida ─────────────────────────────────────────────
DATA_OUTPUT_PATH=./data/knowledge_base.json

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
