# API key de Anthropic — requerida para la app Streamlit (app/)
ANTHROPIC_API_KEY=sk-ant-api03-...

LOG_LEVEL=INFO
OUTPUT_DIR=./knowledge
RUNS_DIR=./runs

REQUESTS_PER_SECOND=0.5
REQUEST_TIMEOUT=30
MAX_RETRIES=2
USER_AGENT=semantic-layer-fvl/0.1.0
ACCEPT_LANGUAGE=es-CO,es;q=0.9,en;q=0.8

TARGET_BASE_URL=https://valledellili.org
RESPECT_ROBOTS_TXT=true

YOUTUBE_SEARCH_LIMIT=50
NEWS_FEED_LIMIT=50
NEWS_SEARCH_DAYS=365
